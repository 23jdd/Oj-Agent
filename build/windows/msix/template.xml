<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="oj-agent.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Oj-Agent Team\OJ Agent">
    </Installer>
    <PackageInformation
        PackageName="OJ Agent"
        PackageDisplayName="OJ Agent"
        PublisherName="CN=Oj-Agent Team"
        PublisherDisplayName="Oj-Agent Team"
        Version="0.1.0.0"
        PackageDescription="输入算法题目，自动生成题解动画">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.example.ojagent"
                Description="输入算法题目，自动生成题解动画"
                DisplayName="OJ Agent"
                ExecutableName="oj-agent.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>OJ Agent</DisplayName>
            <PublisherDisplayName>Oj-Agent Team</PublisherDisplayName>
            <Description>输入算法题目，自动生成题解动画</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="oj-agent.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
