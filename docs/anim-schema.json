{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OJ-Agent Animation Data",
  "description": "统一动画数据格式，描述算法执行过程的可视化数据",
  "type": "object",
  "required": ["type", "steps"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["array", "twopointer", "slidingwindow", "sorting", "tree", "graph", "dptable", "linkedlist", "stackqueue", "backtracking"],
      "description": "动画类型标识"
    },
    "steps": {
      "type": "array",
      "description": "动画步骤列表，按执行顺序排列",
      "items": { "$ref": "#/$defs/AnimStep" }
    },
    "array": { "$ref": "#/$defs/ArrayConfig" },
    "tree": { "$ref": "#/$defs/TreeConfig" },
    "table": { "$ref": "#/$defs/DpTableConfig" },
    "list": { "$ref": "#/$defs/LinkedListConfig" },
    "graph": { "$ref": "#/$defs/GraphConfig" }
  },

  "$defs": {
    "AnimStep": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "步骤描述文本"
        },
        "values": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "当前数组值（用于 array/twopointer/sorting/slidingwindow）"
        },
        "highlightIdx": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "高亮索引（蓝色）"
        },
        "compareIdx": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "正在比较的索引（黄色）"
        },
        "resultIdx": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "最终结果索引（绿色）"
        },
        "swapIdx": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "正在交换的两个索引"
        },
        "pivotIdx": {
          "type": "integer",
          "description": "排序算法中的基准索引"
        },
        "pointerLeft": {
          "type": "integer",
          "description": "左指针位置"
        },
        "pointerRight": {
          "type": "integer",
          "description": "右指针位置"
        },
        "pointerMid": {
          "type": "integer",
          "description": "中间指针位置（二分查找）"
        },
        "windowStart": {
          "type": "integer",
          "description": "滑动窗口起始索引"
        },
        "windowEnd": {
          "type": "integer",
          "description": "滑动窗口结束索引"
        },
        "row": {
          "type": "integer",
          "description": "DP表中的当前行"
        },
        "col": {
          "type": "integer",
          "description": "DP表中的当前列"
        },
        "cellValue": {
          "type": "string",
          "description": "填充到单元格的值"
        },
        "tableGrid": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" } },
          "description": "DP表当前完整状态"
        },
        "nodeId": {
          "type": "string",
          "description": "当前操作的树/图/链表节点ID"
        },
        "nodePath": {
          "type": "array",
          "items": { "type": "string" },
          "description": "已访问的节点路径（树遍历/图遍历）"
        },
        "listNodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ListNode" },
          "description": "链表当前节点状态"
        },
        "stackValues": {
          "type": "array",
          "items": { "type": "string" },
          "description": "栈/队列当前元素"
        },
        "operation": {
          "type": "string",
          "enum": ["push", "pop", "enqueue", "dequeue", "peek"],
          "description": "栈/队列操作类型"
        },
        "operand": {
          "type": "string",
          "description": "操作的操作数（push/enqueue的值）"
        }
      }
    },

    "ArrayConfig": {
      "type": "object",
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "初始数组值"
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "数组元素标签"
        }
      }
    },

    "TreeConfig": {
      "type": "object",
      "properties": {
        "root": { "type": "string", "description": "根节点ID" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/TreeNodeData" }
        }
      }
    },

    "TreeNodeData": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "string" },
        "left": { "type": "string", "description": "左子节点ID" },
        "right": { "type": "string", "description": "右子节点ID" },
        "x": { "type": "integer", "description": "渲染X坐标" },
        "y": { "type": "integer", "description": "渲染Y坐标" }
      },
      "required": ["id", "value", "x", "y"]
    },

    "DpTableConfig": {
      "type": "object",
      "properties": {
        "rows": { "type": "integer", "description": "表格行数" },
        "cols": { "type": "integer", "description": "表格列数" },
        "rowHeaders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "行标题"
        },
        "colHeaders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "列标题"
        }
      }
    },

    "LinkedListConfig": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ListNode" }
        }
      }
    },

    "ListNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "string" },
        "next": { "type": "string", "description": "下一个节点ID" },
        "x": { "type": "integer" },
        "y": { "type": "integer" }
      },
      "required": ["id", "value", "x", "y"]
    },

    "GraphConfig": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphNode" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphEdge" }
        }
      }
    },

    "GraphNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "x": { "type": "integer" },
        "y": { "type": "integer" }
      },
      "required": ["id", "label", "x", "y"]
    },

    "GraphEdge": {
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "weight": { "type": "integer" }
      },
      "required": ["from", "to"]
    }
  }
}
