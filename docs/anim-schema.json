{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OJ-Agent Unified Animation Format",
  "description": "通用元素+帧动画模型，一套 schema 覆盖所有算法可视化类型",
  "type": "object",
  "required": ["elements", "frames", "svgW", "svgH"],
  "properties": {
    "elements": {
      "type": "array",
      "description": "初始场景中的所有可视元素",
      "items": { "$ref": "#/$defs/Element" }
    },
    "frames": {
      "type": "array",
      "description": "动画帧序列，每帧只描述相对于上一帧的变化量(delta)",
      "items": { "$ref": "#/$defs/Frame" }
    },
    "svgW": { "type": "number", "description": "SVG viewBox 宽度" },
    "svgH": { "type": "number", "description": "SVG viewBox 高度" }
  },

  "$defs": {
    "Element": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "description": "唯一标识符，如 cell_0, edge_2, ptr_l" },
        "kind": {
          "type": "string",
          "enum": ["rect", "circle", "line", "label"],
          "description": "元素形状类型"
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "description": "rect 宽度" },
        "h": { "type": "number", "description": "rect 高度" },
        "r": { "type": "number", "description": "circle 半径" },
        "x2": { "type": "number", "description": "line 终点 X" },
        "y2": { "type": "number", "description": "line 终点 Y" },
        "text": { "type": "string", "description": "显示文字" },
        "style": {
          "type": "string",
          "enum": ["normal", "highlight", "compare", "swap", "result", "pivot", "dim"],
          "default": "normal",
          "description": "颜色状态"
        },
        "rx": { "type": "number", "description": "rect 圆角" },
        "visible": { "type": "boolean", "default": true },
        "arrow": { "type": "boolean", "description": "line 是否有箭头" }
      }
    },

    "Frame": {
      "type": "object",
      "required": ["desc"],
      "properties": {
        "desc": { "type": "string", "description": "本帧的描述文字" },
        "delta": {
          "type": "object",
          "description": "元素ID -> 变更属性，只传变化的部分",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" },
              "text": { "type": "string" },
              "style": { "type": "string" },
              "visible": { "type": "boolean" }
            }
          }
        }
      }
    }
  },

  "examples": {
    "array_twoSum": {
      "elements": [
        {"id":"cell_0","kind":"rect","x":30,"y":30,"w":48,"h":42,"text":"2","style":"normal","rx":6,"visible":true},
        {"id":"cell_1","kind":"rect","x":86,"y":30,"w":48,"h":42,"text":"7","style":"normal","rx":6,"visible":true},
        {"id":"hash_hint","kind":"label","x":30,"y":108,"text":"哈希表: {}","style":"dim"}
      ],
      "frames": [
        {"desc":"i=0, v=2, 存入map", "delta":{"cell_0":{"style":"highlight"},"hash_hint":{"text":"哈希表: {2:0}"}}},
        {"desc":"i=1, v=7, 命中!", "delta":{"cell_0":{"style":"compare"},"cell_1":{"style":"highlight"}}},
        {"desc":"返回 [0,1]", "delta":{"cell_0":{"style":"result"},"cell_1":{"style":"result"}}}
      ],
      "svgW": 430,
      "svgH": 168
    },

    "tree_inorder": {
      "elements": [
        {"id":"n_1","kind":"circle","x":300,"y":50,"r":22,"text":"1","style":"normal","visible":true},
        {"id":"n_2","kind":"circle","x":170,"y":160,"r":22,"text":"2","style":"normal","visible":true},
        {"id":"edge_0","kind":"line","x":300,"y":72,"x2":170,"y2":138,"style":"#4b5563","visible":true},
        {"id":"path_label","kind":"label","x":320,"y":330,"text":"","style":"dim"}
      ],
      "frames": [
        {"desc":"从根节点1开始","delta":{"n_1":{"style":"highlight"}}},
        {"desc":"递归→节点2","delta":{"n_1":{"style":"dim"},"n_2":{"style":"highlight"},"edge_0":{"style":"#3b82f6"}}},
        {"desc":"输出 2","delta":{"n_2":{"style":"result"},"path_label":{"text":"输出: [2]"}}}
      ],
      "svgW": 560,
      "svgH": 380
    },

    "linkedlist_reverse": {
      "elements": [
        {"id":"n0","kind":"rect","x":30,"y":50,"w":52,"h":38,"text":"1","style":"highlight","rx":6,"visible":true},
        {"id":"edge_0","kind":"line","x":82,"y":69,"x2":100,"y2":69,"style":"#4b5563","arrow":true,"visible":true},
        {"id":"n1","kind":"rect","x":100,"y":50,"w":52,"h":38,"text":"2","style":"normal","rx":6,"visible":true},
        {"id":"head_label","kind":"label","x":56,"y":34,"text":"head","style":"dim"}
      ],
      "frames": [
        {"desc":"prev=nil, curr=1","delta":{"n0":{"style":"highlight"},"n1":{"style":"highlight"}}},
        {"desc":"1.Next=nil, prev=1","delta":{"n0":{"style":"result"},"n1":{"style":"highlight"},"edge_0":{"style":"dim"}}}
      ],
      "svgW": 400,
      "svgH": 160
    }
  }
}
